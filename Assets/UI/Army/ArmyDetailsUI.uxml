<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/ArmyDetailsStyle.uss?fileID=7433441132597879392&amp;guid=99eec35b80a57fd4e8ec0f21c06bfa41&amp;type=3#ArmyDetailsStyle" />
    <Style src="project://database/Assets/UI%20Toolkit/StandardStyle.uss?fileID=7433441132597879392&amp;guid=96c830d546033024a9981dc4e32e716f&amp;type=3#StandardStyle" />
    <ui:VisualElement name="UnitDetailsPanel" picking-mode="Ignore" style="flex-grow: 1; position: absolute; top: 81px; right: 8px; align-items: flex-end;">
        <ui:VisualElement style="flex-grow: 1; flex-direction: row-reverse; align-items: auto; justify-content: flex-start; align-self: auto; align-content: auto; display: flex;">
            <ui:VisualElement name="MainPanel" class="panel" style="width: 160px; top: auto;">
                <ui:VisualElement style="flex-grow: 0; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; width: auto; height: 17px; align-self: auto; flex-direction: row-reverse; align-content: auto; align-items: stretch; margin-top: 2px;">
                    <ui:Button text="X" name="CloseButton" style="width: 19px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: middle-center; font-size: 10px; -unity-font-style: bold;" />
                    <ui:Label text="Unit" name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 7px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: normal; font-size: 10px; color: rgb(156, 156, 156); flex-grow: 1; -unity-text-align: middle-left;" />
                </ui:VisualElement>
                <ui:VisualElement style="flex-grow: 0; margin-top: 0; margin-right: 7px; margin-bottom: 5px; margin-left: 7px;">
                    <ui:Label text="12th Division" name="ArmyNameLabel" style="margin-top: 5px; margin-right: 0; margin-bottom: 10px; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; color: rgb(255, 255, 255); white-space: normal;" />
                    <ui:VisualElement style="flex-grow: 0; flex-direction: row;">
                        <ui:Label text="Commander" name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 11px; color: rgb(156, 156, 156); flex-grow: 1;" />
                        <ui:Button text="Change" name="ChangeCommanderButton" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 3px; padding-bottom: 0; padding-left: 3px; font-size: 11px; -unity-font-style: normal; -unity-text-align: middle-center; height: 15px;" />
                    </ui:VisualElement>
                    <ui:Label text="Legion Commander" name="CommanderNameLabel" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: normal; font-size: 11px; color: rgb(255, 255, 255);" />
                    <ui:VisualElement name="MoralePanel" style="flex-grow: 0; flex-direction: row; margin-top: 8px;">
                        <ui:Label text="Morale" style="margin-top: 0; margin-right: 10px; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; -unity-text-align: middle-left; width: 53px; color: rgb(112, 191, 207);" />
                        <ui:Label text="100%" name="MoraleLabel" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; -unity-text-align: middle-right; width: auto; color: rgb(112, 191, 207); flex-grow: 1;" />
                    </ui:VisualElement>
                    <ui:VisualElement name="SupplyPanel" style="flex-grow: 0; flex-direction: row; margin-top: 2px;">
                        <ui:Label text="Supply" style="margin-top: 0; margin-right: 10px; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; -unity-text-align: middle-left; width: 53px; color: rgb(190, 139, 82);" />
                        <ui:Label text="100%" name="SupplyLabel" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; -unity-text-align: middle-right; width: 53px; color: rgb(190, 139, 82); flex-grow: 1;" />
                    </ui:VisualElement>
                    <ui:VisualElement name="ActionsLeftPanel" style="flex-grow: 0; flex-direction: row; margin-top: 2px;">
                        <ui:Label text="Actions left" style="margin-top: 0; margin-right: 10px; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; -unity-text-align: middle-left; width: 71px; color: rgb(156, 156, 156);" />
                        <ui:Label text="0" name="ActionsLeftLabel" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; -unity-text-align: middle-right; width: 53px; color: rgb(156, 156, 156); flex-grow: 1;" />
                    </ui:VisualElement>
                    <ui:VisualElement name="SizePanel" style="flex-grow: 0; flex-direction: row; margin-top: 10px; margin-bottom: 5px;">
                        <ui:Label text="Size" selectable="true" focusable="true" style="margin-top: 0; margin-right: 10px; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; -unity-text-align: middle-left; width: 40px; color: rgb(255, 255, 255);" />
                        <ui:VisualElement style="flex-grow: 1; background-color: rgb(63, 63, 63); border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px;">
                            <ui:Label text="12,513" name="SizeLabel" style="margin-top: 4px; margin-right: 4px; margin-bottom: 4px; margin-left: 4px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; font-size: 14px; -unity-font-style: bold; -unity-text-align: upper-right; color: rgb(255, 255, 255);" />
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement style="flex-grow: 0; flex-direction: column;">
                        <ui:VisualElement style="flex-grow: 1; flex-direction: row;">
                            <ui:Button text="Split" name="SplitButton" style="height: 18px; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0; margin-right: 1px; margin-bottom: 2px; margin-left: 0; font-size: 12px; flex-grow: 1;" />
                        </ui:VisualElement>
                        <ui:Button text="Resupply" name="ResupplyButton" style="height: 18px; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 2px; margin-left: 0; font-size: 12px; flex-grow: 1;" />
                        <ui:Button text="Merge" name="MergeButton" style="height: 18px; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; font-size: 12px; flex-grow: 1;" />
                        <ui:Button text="Disband" name="DisbandButton" selectable="false" focusable="false" style="height: 18px; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 2px; margin-right: 0; margin-bottom: 2px; margin-left: 0; font-size: 12px; flex-grow: 1; background-color: rgb(255, 138, 138); border-left-color: rgb(255, 165, 165); border-right-color: rgb(255, 165, 165); border-top-color: rgb(255, 165, 165); border-bottom-color: rgb(255, 165, 165);" />
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="ChangeCommanderPanel" class="panel" style="flex-grow: 0; position: relative; width: 275px; height: auto; align-self: stretch; left: auto; background-color: rgb(43, 43, 43); margin-top: 0; margin-right: 2px; margin-bottom: 0; margin-left: 0; top: 5px; align-items: stretch; align-content: flex-start; justify-content: center; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; right: auto; bottom: auto; padding-top: 9px; padding-right: 9px; padding-bottom: 9px; padding-left: 9px; display: none; visibility: visible; max-height: 280px;">
                <ui:VisualElement style="flex-grow: 0; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; width: 100%; height: 17px; align-self: flex-start; flex-direction: row-reverse; align-content: auto; align-items: stretch; margin-top: 0; margin-right: 0; margin-bottom: 9px; margin-left: 0; display: flex; visibility: visible; overflow: visible;">
                    <ui:Button text="X" name="CloseButton" style="width: 19px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: middle-center; font-size: 10px; -unity-font-style: bold;" />
                    <ui:Label text="Change commander" name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; color: rgb(255, 255, 255); flex-grow: 1; -unity-text-align: lower-left;" />
                </ui:VisualElement>
                <ui:Label text="Changes a unit&apos;s commander." style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: normal; font-size: 10px; color: rgb(125, 125, 125); flex-grow: 0; -unity-text-align: upper-left; white-space: pre-wrap; height: auto;" />
                <ui:VisualElement name="VisualElement" style="flex-grow: 1; flex-direction: column; justify-content: flex-start; margin-top: 6px; margin-right: 5px; margin-left: 5px;">
                    <ui:Label text="Current" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 11px; color: rgb(156, 156, 156); flex-grow: 0;" />
                    <ui:Label text="Legion Commander" name="CurrentCommanderLabel" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: normal; font-size: 11px; color: rgb(255, 255, 255);" />
                    <ui:Label text="New" style="margin-top: 5px; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 11px; color: rgb(224, 185, 123); flex-grow: 0;" />
                    <ui:VisualElement style="flex-grow: 0; flex-direction: row;">
                        <ui:Label text="None" name="NewCommanderLabel" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: normal; font-size: 11px; color: rgb(255, 255, 255); -unity-text-align: middle-left; flex-grow: 1;" />
                        <ui:Button text="Remove" name="RemoveCommanderButton" style="padding-top: 0; padding-right: 5px; padding-bottom: 0; padding-left: 5px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; font-size: 12px;" />
                    </ui:VisualElement>
                    <ui:ListView item-template="project://database/Assets/UI/Army/CommanderItem.uxml?fileID=9197481963319205126&amp;guid=e8b446dfd6bb7f6408423d4edbf622bc&amp;type=3#CommanderItem" fixed-item-height="30" virtualization-method="DynamicHeight" style="flex-grow: 1; margin-top: 7px;" />
                    <ui:Button text="Change" name="ChangeCommanderButton" style="height: 22px; font-size: 12px; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 8px; margin-right: 0; margin-bottom: 0; margin-left: 0;" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="SplitUnitPanel" class="panel" style="flex-grow: 0; position: relative; width: 200px; height: auto; align-self: flex-end; left: auto; background-color: rgb(43, 43, 43); margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; top: 5px; align-items: stretch; align-content: flex-start; justify-content: flex-start; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; right: auto; bottom: auto; padding-top: 9px; padding-right: 9px; padding-bottom: 9px; padding-left: 9px; display: none; visibility: visible;">
            <ui:VisualElement style="flex-grow: 0; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; width: 100%; height: 17px; align-self: flex-start; flex-direction: row-reverse; align-content: auto; align-items: stretch; margin-top: 0; margin-right: 0; margin-bottom: 9px; margin-left: 0;">
                <ui:Button text="X" name="CloseButton" style="width: 19px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: middle-center; font-size: 10px; -unity-font-style: bold;" />
                <ui:Label text="Split unit" name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; color: rgb(255, 255, 255); flex-grow: 1; -unity-text-align: lower-left;" />
            </ui:VisualElement>
            <ui:Label text="Split a unit into two units,  retaining their basic stats except size." name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: normal; font-size: 10px; color: rgb(125, 125, 125); flex-grow: 0; -unity-text-align: upper-left; white-space: pre-wrap; height: auto;" />
            <ui:VisualElement name="VisualElement" style="flex-grow: 0; flex-direction: column; justify-content: flex-start; margin-top: 6px;">
                <ui:VisualElement name="SourceUnit" style="flex-grow: 0; flex-direction: row; height: 18px;">
                    <ui:Label text="None" name="SourceName" style="color: rgb(123, 123, 123); -unity-text-align: middle-left; width: 120px; -unity-font-style: normal; font-size: 10px; flex-grow: 1;" />
                    <ui:Button text="Select" name="SelectSourceButton" style="margin-top: 0; margin-right: 5px; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 1; font-size: 12px; display: none;" />
                    <ui:Button text="X" name="DeselectSourceButton" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 0; font-size: 12px; width: 18px; visibility: visible; display: none;" />
                </ui:VisualElement>
                <ui:VisualElement style="flex-grow: 1; flex-direction: row; align-items: center; margin-top: 6px;">
                    <ui:Label text="New Unit Size" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 10px; color: rgb(255, 255, 255); flex-grow: 0; -unity-text-align: middle-left; white-space: pre-wrap; height: 100%; width: 106px;" />
                    <ui:IntegerField value="0" name="NewUnitSizeField" max-length="7" keyboard-type="Default" password="false" style="height: 22px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; font-size: 12px; flex-grow: 1;" />
                </ui:VisualElement>
                <ui:Button text="Split" name="SplitButton" style="height: 22px; font-size: 12px; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 8px; margin-right: 0; margin-bottom: 0; margin-left: 0;" />
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="ResupplyUnitPanel" class="panel" style="flex-grow: 0; position: relative; width: 209px; height: 183px; align-self: flex-end; left: auto; background-color: rgb(43, 43, 43); margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; top: 5px; align-items: stretch; align-content: flex-start; justify-content: flex-start; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; right: auto; bottom: auto; padding-top: 9px; padding-right: 9px; padding-bottom: 9px; padding-left: 9px; display: none; visibility: visible;">
            <ui:VisualElement style="flex-grow: 0; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; width: 100%; height: 17px; align-self: flex-start; flex-direction: row-reverse; align-content: auto; align-items: stretch; margin-top: 0; margin-right: 0; margin-bottom: 9px; margin-left: 0;">
                <ui:Button text="X" name="CloseButton" style="width: 19px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: middle-center; font-size: 10px; -unity-font-style: bold;" />
                <ui:Label text="Resupply unit" name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; color: rgb(255, 255, 255); flex-grow: 1; -unity-text-align: lower-left;" />
            </ui:VisualElement>
            <ui:Label text="Replenishes a unit&apos;s supply, boosting the unit&apos;s morale." style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: normal; font-size: 10px; color: rgb(125, 125, 125); flex-grow: 0; -unity-text-align: upper-left; white-space: pre-wrap; height: auto;" />
            <ui:VisualElement name="VisualElement" style="flex-grow: 0; flex-direction: column; justify-content: flex-start; margin-top: 6px;">
                <ui:VisualElement name="SourceUnit" style="flex-grow: 0; flex-direction: row; height: 18px;">
                    <ui:Label text="None" name="SourceName" style="color: rgb(123, 123, 123); -unity-text-align: middle-left; width: 120px; -unity-font-style: normal; font-size: 10px; flex-grow: 1;" />
                    <ui:Button text="Select" name="SelectSourceButton" style="margin-top: 0; margin-right: 5px; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 1; font-size: 12px; display: none;" />
                    <ui:Button text="X" name="DeselectSourceButton" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 0; font-size: 12px; width: 18px; display: none;" />
                </ui:VisualElement>
                <ui:VisualElement style="flex-grow: 1; flex-direction: row; align-items: center; margin-top: 6px;">
                    <ui:Label text="Amount" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 10px; color: rgb(255, 255, 255); flex-grow: 0; -unity-text-align: middle-left; white-space: pre-wrap; height: 100%; width: 119px;" />
                    <ui:IntegerField value="0" name="ResupplyAmount" max-length="3" keyboard-type="Default" style="height: 22px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; font-size: 12px; flex-grow: 1;" />
                    <ui:Label text="%" name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 4px; -unity-font-style: bold; font-size: 10px; color: rgb(255, 255, 255); flex-grow: 0; -unity-text-align: middle-left; white-space: pre-wrap; height: 100%; width: auto;" />
                </ui:VisualElement>
                <ui:VisualElement style="flex-grow: 1; flex-direction: row; margin-top: 5px;">
                    <ui:Label text="Supply needed" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 10px; color: rgb(255, 255, 255); flex-grow: 1; -unity-text-align: middle-left; white-space: pre-wrap; height: auto;" />
                    <ui:Label text="50%" name="SupplyNeededLabel" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 10px; color: rgb(255, 255, 255); flex-grow: 0; -unity-text-align: middle-left; white-space: pre; height: auto;" />
                </ui:VisualElement>
                <ui:VisualElement style="flex-grow: 1; flex-direction: row; margin-top: 5px;">
                    <ui:Label text="Total cost&#10;" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 10px; color: rgb(255, 171, 81); flex-grow: 1; -unity-text-align: middle-left; white-space: pre-wrap; height: auto;" />
                    <ui:Label text="10,000" name="TotalCostLabel" class="cost-label" />
                </ui:VisualElement>
                <ui:Button text="Resupply" name="ResupplyButton" style="height: 22px; font-size: 12px; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 8px; margin-right: 0; margin-bottom: 0; margin-left: 0;" />
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="MergePanel" style="flex-grow: 0; position: relative; width: 209px; height: 126px; align-self: flex-end; left: auto; background-color: rgb(43, 43, 43); margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; top: 5px; align-items: stretch; align-content: flex-start; justify-content: flex-start; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; right: auto; bottom: auto; padding-top: 9px; padding-right: 9px; padding-bottom: 9px; padding-left: 9px; display: none; visibility: visible;">
            <ui:VisualElement style="flex-grow: 0; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; width: 100%; height: 17px; align-self: flex-start; flex-direction: row-reverse; align-content: auto; align-items: stretch; margin-top: 0; margin-right: 0; margin-bottom: 9px; margin-left: 0;">
                <ui:Button text="X" name="CloseButton" style="width: 19px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: middle-center; font-size: 10px; -unity-font-style: bold;" />
                <ui:Label text="Merge units" name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 12px; color: rgb(255, 255, 255); flex-grow: 1; -unity-text-align: lower-left;" />
            </ui:VisualElement>
            <ui:Label text="Both units must be in the same commandery to merge." name="Label" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: normal; font-size: 10px; color: rgb(125, 125, 125); flex-grow: 0; -unity-text-align: upper-left; white-space: pre-wrap; height: auto;" />
            <ui:VisualElement name="VisualElement" style="flex-grow: 0; flex-direction: column; justify-content: flex-start; margin-top: 6px;">
                <ui:VisualElement name="TargetUnit" style="flex-grow: 0; flex-direction: row; height: 18px; -unity-font-style: normal; margin-top: 2px;">
                    <ui:Label text="None" name="TargetName" style="color: rgb(123, 123, 123); -unity-text-align: middle-left; width: auto; -unity-font-style: normal; font-size: 10px; flex-grow: 1;" />
                </ui:VisualElement>
                <ui:Button text="Merge" name="MergeButton" style="height: 22px; font-size: 12px; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 8px; margin-right: 0; margin-bottom: 0; margin-left: 0;" />
