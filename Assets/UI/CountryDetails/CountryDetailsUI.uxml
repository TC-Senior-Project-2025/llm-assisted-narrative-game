<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/StandardStyle.uss?fileID=7433441132597879392&amp;guid=96c830d546033024a9981dc4e32e716f&amp;type=3#StandardStyle" />
    <ui:VisualElement picking-mode="Ignore" style="flex-grow: 1; align-items: center; justify-content: center;">
        <ui:VisualElement name="CountryDetailsPanel" class="panel" style="flex-grow: 0; height: 214px; width: 309px; padding-top: 12px; padding-right: 12px; padding-bottom: 12px; padding-left: 12px; visibility: visible;">
            <ui:VisualElement name="VisualElement" style="flex-grow: 0; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; width: auto; height: auto; align-self: auto; flex-direction: row-reverse; align-content: auto; align-items: stretch; margin-top: 0; margin-bottom: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-right: 0; margin-left: 0;">
                <ui:Button text="X" name="CloseButton" style="width: 16px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: middle-center; font-size: 10px; -unity-font-style: bold; height: 16px;" />
                <ui:Label text="People in Court" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 10px; color: rgb(255, 255, 255); flex-grow: 1; -unity-text-align: middle-left; height: 16px;" />
            </ui:VisualElement>
            <ui:VisualElement name="VisualElement" style="flex-grow: 0; flex-direction: row; margin-top: 5px;">
                <ui:Button text="People" style="height: 18px; font-size: 10px; width: auto; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 1; -unity-font-style: bold;" />
            </ui:VisualElement>
            <ui:ListView item-template="project://database/Assets/UI/CountryDetails/PeopleItem.uxml?fileID=9197481963319205126&amp;guid=d71f66f8c5a1b0543961da5bf3abc843&amp;type=3#PeopleItem" fixed-item-height="55" virtualization-method="DynamicHeight" style="flex-grow: 1; margin-top: 7px; color: rgb(255, 255, 255); font-size: 11px; height: auto;" />
        </ui:VisualElement>
        <ui:VisualElement name="PersonDetailsPanel" class="panel" style="flex-grow: 0; width: 309px; height: 128px; margin-top: 5px; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; display: flex; visibility: visible;">
            <ui:VisualElement name="VisualElement" style="flex-grow: 0; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; width: auto; height: auto; align-self: auto; flex-direction: row-reverse; align-content: auto; align-items: stretch; margin-top: 0; margin-bottom: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-right: 0; margin-left: 0;">
                <ui:Button text="X" name="CloseButton" style="width: 16px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: middle-center; font-size: 10px; -unity-font-style: bold; height: 16px;" />
                <ui:Label text="FirstName LastName (Age)" name="NameLabel" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; font-size: 10px; color: rgb(255, 255, 255); flex-grow: 1; -unity-text-align: middle-left; height: 16px;" />
            </ui:VisualElement>
            <ui:VisualElement style="flex-grow: 0; flex-direction: row; margin-top: 2px;">
                <ui:Label text="King" name="RoleLabel" style="padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; color: rgb(140, 140, 140); font-size: 10px; -unity-font-style: normal; flex-grow: 1;" />
                <ui:Label text="Alive" name="StatusLabel" style="padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; color: rgb(128, 243, 120); font-size: 10px; -unity-font-style: bold; -unity-text-align: middle-left;" />
            </ui:VisualElement>
            <ui:ListView virtualization-method="DynamicHeight" item-template="project://database/Assets/UI/CountryDetails/PersonStat.uxml?fileID=9197481963319205126&amp;guid=b6d3e839d00a2bf4f8918a2f43bea2c7&amp;type=3#PersonStat" style="flex-grow: 1; margin-top: 5px; display: flex;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
