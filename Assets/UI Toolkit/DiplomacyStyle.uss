:root {
}

.accept {
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    color: rgb(188, 229, 143);
    -unity-font-style: normal;
    -unity-text-align: middle-right;
    flex-grow: 1;
    font-size: 11px;
}

.reject {
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    color: rgb(212, 135, 127);
    -unity-font-style: normal;
    -unity-text-align: middle-right;
    flex-grow: 1;
    font-size: 11px;
}
